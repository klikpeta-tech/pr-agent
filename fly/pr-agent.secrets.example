# pr-agent Fly.io secrets — set via:
#   fly secrets set --app klikpeta-pr-agent KEY=VALUE
#
# NOTE: Fly.io env var names cannot contain ".", use "__" as separator instead.

# GitHub App credentials (from https://github.com/organizations/klikpeta-tech/settings/apps)
GITHUB__APP_ID=<numeric-app-id>
GITHUB__WEBHOOK_SECRET=<secret-from-step-2>
# Paste the full contents of the .pem private key file (newlines replaced with \n)
GITHUB__PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----

# LLM provider — choose one:
OPENAI__KEY=<your-openai-api-key>
# ANTHROPIC__KEY=<your-anthropic-api-key>

# If using Anthropic Claude as the model, also set:
# CONFIG__AI__MODEL=anthropic/claude-3-5-sonnet-20241022
